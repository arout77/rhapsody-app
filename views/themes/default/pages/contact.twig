{% extends "@core/layouts/main.twig" %}

{% block content %}
<div class="max-w-xl mx-auto py-12 px-4">
    <h1 class="text-3xl font-bold mb-6">Contact</h1>

    {% if flash.success %}
        <div class="mb-4 p-3 rounded bg-green-100 text-green-800">{{ flash.success }}</div>
    {% endif %}

    <form method="post" action="{{ base_url }}/contact" class="space-y-4">
        {{ csrf_field() }}

        <div>
            <label class="block text-sm font-medium mb-1" for="name">Name</label>
            <input type="text" id="name" name="name" value="{{ old.name|default('') }}"
                   class="w-full border rounded px-3 py-2">
            {% if errors.name %}<p class="text-red-600 text-sm mt-1">{{ errors.name }}</p>{% endif %}
        </div>

        <div>
            <label class="block text-sm font-medium mb-1" for="email">Email</label>
            <input type="email" id="email" name="email" value="{{ old.email|default('') }}"
                   class="w-full border rounded px-3 py-2">
            {% if errors.email %}<p class="text-red-600 text-sm mt-1">{{ errors.email }}</p>{% endif %}
        </div>

        <div>
            <label class="block text-sm font-medium mb-1" for="message">Message</label>
            <textarea id="message" name="message" rows="5"
                      class="w-full border rounded px-3 py-2">{{ old.message|default('') }}</textarea>
            {% if errors.message %}<p class="text-red-600 text-sm mt-1">{{ errors.message }}</p>{% endif %}
        </div>

        <button type="submit" class="px-6 py-2 bg-indigo-600 text-white rounded">Send</button>
    </form>
</div>
{% endblock %}
