{
    "name": "arout/rhapsody-app",
    "description": "The skeleton application for the Rhapsody Framework",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Andrew Rout",
            "email": "andrew@rhapsody-framework.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "arout/rhapsody-core": "dev-main",
        "twig/twig": "^3.21",
        "league/omnipay": "^3.0",
        "omnipay/stripe": "^3.0",
        "omnipay/paypal": "^3.0",
        "vlucas/phpdotenv": "^5.6",
        "symfony/mailer": "^7.3",
        "filp/whoops": "^2.18",
        "symfony/console": "^7.3",
        "robmorgan/phinx": "^0.16.10",
        "symfony/process": "^7.3",
        "doctrine/orm": "^2.17",
        "doctrine/dbal": "^3.7",
        "symfony/cache": "^7.0",
        "predis/predis": "^2.2",
        "intervention/image": "^3.11"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "rhapsody": "@php vendor/bin/rhapsody",
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}