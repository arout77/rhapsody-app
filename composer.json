{
    "name": "arout/rhapsody-app",
    "description": "The skeleton application for the Rhapsody Framework",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Andrew Rout",
            "email": "andrew@rhapsody-framework.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "arout/rhapsody-core": "dev-main",
        "league/oauth2-client": "^2.0",
        "league/oauth2-google": "^3.0",
        "league/oauth2-facebook": "^2.0",
        "omnipay/omnipay": "^3.0",
        "omnipay/stripe": "^3.0",
        "omnipay/paypal": "^3.0",
        "stripe/stripe-php": "^15.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.2",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Rhapsody\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "rhapsody": "@php vendor/bin/rhapsody",
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
